<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio | Guy Orlov - Data Analyst</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        body {
            font-family: 'Arial', sans-serif;
            margin: 0;
            background-color: #000;
            color: #fff;
        }
        .service-title {
            font-size: 2.5em;
            font-weight: bold;
            margin-bottom: 20px;
            color: #fff;
        }
        #project-boxes {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        .service-box {
            width: 90%;
            background: #111;
            border: 1px solid #333;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
            text-align: center;
        }
        .service-box i {
            font-size: 2em;
            color: #00bcd4;
            margin-bottom: 10px;
        }
        .service-box h3 {
            font-size: 1.5em;
            font-weight: bold;
            color: #fff;
            margin-bottom: 15px;
        }
        .service-box p {
            color: #aaa;
            font-size: 1em;
            line-height: 1.6;
        }
    </style>
</head>
<body>
    <section id="portfolio" style="background-color: #000; color: #fff; padding: 50px 20px;">
        <div style="max-width: 1200px; margin: 0 auto; text-align: center;">
            <h2 class="service-title">Portfolio</h2>
            <p style="font-size: 1.2em; color: #ccc; margin-bottom: 40px;">
                Showcasing my work in data analysis, visualization, and storytelling.
            </p>

            <!-- Flex Container for Project Boxes -->
            <div id="project-boxes">

                <!-- Project Box 1 -->
                <div class="service-box">
                    <i class="fas fa-chart-bar"></i>
                    <h3>POWER BI DESKTOP | Figma</h3>
                    <p>
                        The dashboard focuses on the Economic inactivity of Disabled People, providing key insights for educators and training providers.
                    </p>
                </div>

                <!-- Project Box 2 -->
                <div class="service-box">
                    <i class="fas fa-chart-pie"></i>
                    <h3>TABLEAU DESKTOP | FIGMA</h3>
                    <p>
                        My first Tableau project, involving data cleaning, Power Query, and dashboard design with Figma.
                    </p>
                </div>

                <!-- Project Box 3 -->
                <div class="service-box">
                    <i class="fas fa-users"></i>
                    <h3>POWER BI DESKTOP | POWERPOINT</h3>
                    <p>
                        A project for Deaf Together Wales to highlight the inclusion of deaf people through events and activities.
                    </p>
                </div>

                <!-- Project Box 4 -->
                <div class="service-box">
                    <i class="fas fa-balance-scale"></i>
                    <h3>POWER BI DESKTOP | POWERPOINT</h3>
                    <p>
                        A translated dashboard for the Office for National Statistics to address crime impacts on disabled people.
                    </p>
                </div>
            </div>
        </div>
    </section>
</body>
</html>
